  <script>
    // ── Cursor ──
    const cursor = document.getElementById('cursor');
    const ring   = document.getElementById('cursorRing');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
    (function animCursor() {
      cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
      rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12;
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(animCursor);
    })();
    function bindCursor() {
      document.querySelectorAll('a, button').forEach(el => {
        el.addEventListener('mouseenter', () => { ring.style.width = '56px'; ring.style.height = '56px'; });
        el.addEventListener('mouseleave', () => { ring.style.width = '36px'; ring.style.height = '36px'; });
      });
    }
    bindCursor();

    // ── Gallery data ──
    const photos = [
      { src: 'https://images.unsplash.com/photo-1519125323398-675f0ddb6308?w=1200&q=85', title: 'Before Dawn',    cat: 'landscape', body: 'Caught between night and first light — the mountain holds its breath before the world wakes.',  series: 'Alpenglow',        medium: 'Digital Photography',    year: '2024' },
      { src: 'https://images.unsplash.com/photo-1531306728370-e2ebd9d7bb99?w=1200&q=85', title: 'Solitude I',     cat: 'portrait',  body: 'A study in stillness. The subject asked to be shown as they feel, not as they appear.',         series: 'Inner Landscapes', medium: 'Film — 35mm',             year: '2023' },
      { src: 'https://images.unsplash.com/photo-1470770903676-69b98201ea1c?w=1200&q=85', title: 'Golden Hour',    cat: 'landscape', body: 'Twenty minutes of light that transforms the ordinary into something worth remembering.',         series: 'Alpenglow',        medium: 'Digital Photography',    year: '2024' },
      { src: 'https://images.unsplash.com/photo-1524863479829-916d8e77f114?w=1200&q=85', title: 'Reverie',        cat: 'fine-art',  body: 'The architecture of dreams — structured, yet always just out of reach.',                        series: 'Oneiric',          medium: 'Archival Pigment Print', year: '2023' },
      { src: 'https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?w=1200&q=85', title: 'Passage',        cat: 'editorial', body: 'Shot for a Paris-based publication exploring urban solitude at dusk.',                           series: 'City Nocturne',    medium: 'Digital Photography',    year: '2022' },
      { src: 'https://images.unsplash.com/photo-1551963831-b3b1ca40c98e?w=1200&q=85',   title: 'Fragment',       cat: 'fine-art',  body: 'What remains when context is stripped away? The fragment speaks louder than the whole.',       series: 'Oneiric',          medium: 'Archival Pigment Print', year: '2023' },
      { src: 'https://images.unsplash.com/photo-1465101162946-4377e57745c3?w=1200&q=85', title: 'Night Study',    cat: 'landscape', body: 'The city never fully sleeps — it breathes differently, softer, honest.',                        series: 'City Nocturne',    medium: 'Long Exposure',          year: '2022' },
      { src: 'https://images.unsplash.com/photo-1487222477894-8943e31ef7b2?w=1200&q=85', title: 'In Focus',       cat: 'portrait',  body: 'To be truly seen is rare. This frame was that moment.',                                         series: 'Inner Landscapes', medium: 'Film — 35mm',             year: '2024' },
      { src: 'https://images.unsplash.com/photo-1509021436665-8f07dbf5bf1d?w=1200&q=85', title: 'Between Frames', cat: 'editorial', body: "The image that almost wasn't — taken in the pause between two shots.",                          series: 'City Nocturne',    medium: 'Digital Photography',    year: '2023' },
      { src: 'https://i.postimg.cc/PqbS2tLL/wallpaperflare-com-wallpaper.jpg', title: 'Between Frames', cat: 'editorial', body: "The image that almost wasn't — taken in the pause between two shots.",                          series: 'City Nocturne',    medium: 'Digital Photography',    year: '2023' },
    ];


    // ── Lightbox ──
    const lightbox      = document.getElementById('lightbox');
    let currentIndex    = 0;
    let currentFiltered = [...photos];

    function openLightbox(i) {
      currentIndex = i;
      const p = currentFiltered[i];
      document.getElementById('lbImg').src             = p.src;
      document.getElementById('lbImg').alt             = p.title;
      document.getElementById('lbTitle').textContent   = p.title;
      document.getElementById('lbCat').textContent     = p.cat;
      document.getElementById('lbBody').textContent    = p.body;
      document.getElementById('lbSeries').textContent  = p.series;
      document.getElementById('lbMedium').textContent  = p.medium;
      document.getElementById('lbYear').textContent    = p.year;
      document.getElementById('lbCounter').textContent = `${i + 1} / ${currentFiltered.length}`;
      document.body.style.overflow = 'hidden';
      lightbox.classList.add('open');
    }
    function closeLightbox() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    }
    document.getElementById('lbClose').addEventListener('click', closeLightbox);
    document.getElementById('lbBackdrop').addEventListener('click', closeLightbox);
    document.getElementById('lbPrev').addEventListener('click', e => { e.stopPropagation(); openLightbox((currentIndex - 1 + currentFiltered.length) % currentFiltered.length); });
    document.getElementById('lbNext').addEventListener('click', e => { e.stopPropagation(); openLightbox((currentIndex + 1) % currentFiltered.length); });
    document.addEventListener('keydown', e => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape')     closeLightbox();
      if (e.key === 'ArrowLeft')  document.getElementById('lbPrev').click();
      if (e.key === 'ArrowRight') document.getElementById('lbNext').click();
    });

    // ── Gallery render ──
    const gallery = document.getElementById('gallery');
    function renderGallery(filter) {
      gallery.innerHTML = '';
      currentFiltered = filter === 'all' ? [...photos] : photos.filter(p => p.cat === filter);
      currentFiltered.forEach((p, i) => {
        const item = document.createElement('div');
        item.className = 'gallery-item';
        item.style.transitionDelay = (i * 0.07) + 's';
        item.innerHTML = `
          <img src="${p.src}" alt="${p.title}" loading="lazy"/>
          <div class="gallery-overlay">
            <div class="gallery-info"><h3>${p.title}</h3><p>${p.cat}</p></div>
          </div>`;
        gallery.appendChild(item);
        item.addEventListener('click', () => openLightbox(i));
        setTimeout(() => item.classList.add('visible'), 80 + i * 70);
      });
      bindCursor();
    }
    renderGallery('all');

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderGallery(btn.dataset.filter);
      });
    });

    // ── Scroll reveal (gallery + project blocks) ──
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.08 });
    document.querySelectorAll('.gallery-item, .project-block').forEach(el => observer.observe(el));

    // ── Research notes toggles ──
    document.querySelectorAll('.project-notes-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const notesId = btn.id.replace('toggle', 'notes');
        const notes   = document.getElementById(notesId);
        btn.classList.toggle('open');
        notes.classList.toggle('open');
      });
    });

    // ── GSAP hero title ──
    function wrapLetters(node) {
      if (node.nodeType === 3) {
        const frag = document.createDocumentFragment();
        [...node.textContent].forEach(ch => {
          if (ch === ' ' || ch === '\n') {
            frag.appendChild(document.createTextNode(ch));
          } else {
            const span = document.createElement('span');
            span.className = 'letter';
            span.textContent = ch;
            frag.appendChild(span);
          }
        });
        node.parentNode.replaceChild(frag, node);
      } else if (node.nodeType === 1) {
        [...node.childNodes].forEach(wrapLetters);
      }
    }
    const titleEl = document.querySelector('.hero-title');
    wrapLetters(titleEl);
    gsap.from('.hero-title .letter', {
      duration: 0.9, opacity: 0, y: 80, rotateX: -90,
      transformOrigin: '0% 50% -50px', ease: 'power4.out',
      stagger: 0.04, delay: 0.4
    });

    bindCursor();
  </script>
