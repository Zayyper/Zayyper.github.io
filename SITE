<!DOCTYPE html>
<html lang="en">
<head>
  <script src="https://player.vimeo.com/api/player.js"></script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Portfolio — Loïs Caustrois</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Bebas+Neue&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0c0c0b;
      --surface: #141412;
      --text: #e8e4dc;
      --muted: #7a7468;
      --accent: #c9a96e;
      --accent2: #8b6f4e;
      --border: rgba(201,169,110,0.15);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      cursor: none;
      overflow-x: hidden;
    }

    section, #work, #about, #services, #contact, #projects {
      scroll-margin-top:-50px;
    }

    /* ── Cursor ── */
    .cursor {
      width: 10px; height: 10px; background: var(--accent);
      border-radius: 50%; position: fixed; top: 0; left: 0;
      pointer-events: none; z-index: 9999; transform: translate(-50%, -50%);
      transition: transform 0.1s ease, width 0.3s ease, height 0.3s ease;
      mix-blend-mode: difference;
    }
    .cursor-ring {
      width: 36px; height: 36px; border: 1px solid var(--accent);
      border-radius: 50%; position: fixed; top: 0; left: 0;
      pointer-events: none; z-index: 9998; transform: translate(-50%, -50%);
      transition: transform 0.18s ease, width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
      opacity: 0.6;
    }

    body::before {
      content: ''; position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 9997; opacity: 0.5;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 2rem 3rem;
    }
    nav::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to bottom, rgba(12,12,11,0.9) 0%, transparent 100%);
      z-index: -1;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem;
      letter-spacing: 0.2em; color: var(--text); text-decoration: none;
    }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      color: var(--muted); text-decoration: none; font-size: 0.75rem;
      letter-spacing: 0.12em; text-transform: uppercase; transition: color 0.3s;
    }
    .nav-links a:hover { color: var(--accent); }

    /* ── HERO ── */
    .hero {
      height: 100vh; display: flex; flex-direction: column;
      justify-content: flex-end; padding: 4rem 3rem;
      position: relative; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at 70% 40%, rgba(139,111,78,0.12) 0%, transparent 60%),
        radial-gradient(ellipse at 20% 80%, rgba(201,169,110,0.06) 0%, transparent 50%);
    }
    .hero-img {
      position: absolute; inset: 0;
      background: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600&q=80') center/cover no-repeat;
      opacity: 0.18; filter: grayscale(30%);
    }
    .hero-line {
      position: absolute; right: 3rem; top: 50%; transform: translateY(-50%);
      width: 1px; height: 30vh;
      background: linear-gradient(to bottom, transparent, var(--accent), transparent);
      opacity: 0.5;
    }
    .hero-content { position: relative; max-width: 900px; }
    .hero-eyebrow {
      font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1.5rem;
      opacity: 0; animation: fadeUp 0.8s ease 0.3s forwards;
    }
    .hero-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4rem, 12vw, 11rem);
      line-height: 0.92; letter-spacing: 0.02em; color: var(--text);
    }
    .hero-title em {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 0.85em; color: var(--accent);
    }
    .hero-title .letter { display: inline-block; will-change: transform, opacity; }
    .hero-sub {
      margin-top: 2rem; font-size: 0.85rem; color: var(--muted);
      letter-spacing: 0.08em; max-width: 380px; line-height: 1.7;
      opacity: 0; animation: fadeUp 0.9s ease 1.4s forwards;
    }
    .hero-scroll {
      position: absolute; bottom: 3rem; right: 3rem;
      display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
      opacity: 0; animation: fadeIn 1s ease 1.6s forwards;
    }
    .hero-scroll span {
      font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--muted); writing-mode: vertical-rl;
    }
    .scroll-line {
      width: 1px; height: 60px;
      background: linear-gradient(to bottom, var(--accent), transparent);
      animation: scrollPulse 2s ease infinite;
    }

    /* ── GALLERY ── */
    #work { padding: 8rem 3rem 6rem; }
    .section-header { display: flex; align-items: baseline; gap: 2rem; margin-bottom: 4rem; }
    .section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: 0.05em; }
    .section-number { font-family: 'Cormorant Garamond', serif; font-style: italic; color: var(--accent); font-size: 1rem; }
    .section-rule { flex: 1; height: 1px; background: var(--border); }

    .filters { display: flex; gap: 0.5rem; margin-bottom: 3rem; flex-wrap: wrap; }
    .filter-btn {
      padding: 0.4rem 1.2rem; border: 1px solid var(--border);
      background: transparent; color: var(--muted);
      font-family: 'DM Sans', sans-serif; font-size: 0.7rem;
      letter-spacing: 0.12em; text-transform: uppercase; cursor: none; transition: all 0.3s;
    }
    .filter-btn.active, .filter-btn:hover { background: var(--accent); border-color: var(--accent); color: var(--bg); }

    .gallery-grid { columns: 3; column-gap: 1.2rem; }
    @media (max-width: 900px) { .gallery-grid { columns: 2; } }
    @media (max-width: 560px) { .gallery-grid { columns: 1; } }

    .gallery-item {
      break-inside: avoid; margin-bottom: 1.2rem;
      position: relative; overflow: hidden; display: block;
      opacity: 0; transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease; cursor: none;
    }
    .gallery-item.visible { opacity: 1; transform: none; }
    .gallery-item img {
      width: 100%; display: block;
      filter: grayscale(20%) brightness(0.85);
      transition: transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94), filter 0.5s ease;
    }
    .gallery-item:hover img { transform: scale(1.04); filter: grayscale(0%) brightness(1); }
    .gallery-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(12,12,11,0.85) 0%, transparent 50%);
      opacity: 0; transition: opacity 0.4s ease;
      display: flex; align-items: flex-end; padding: 1.5rem;
    }
    .gallery-item:hover .gallery-overlay { opacity: 1; }
    .gallery-info h3 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.1rem; color: var(--text); }
    .gallery-info p { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-top: 0.25rem; }

    /* ════════════════════════════════
       PROJECTS / RESEARCH SECTION
    ════════════════════════════════ */
    #projects {
      padding: 8rem 3rem;
      border-top: 1px solid var(--border);
      position: relative;
    }

    /* vertical spine */
    .timeline {
      position: relative;
      margin-top: 5rem;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0; bottom: 0;
      width: 1px;
      background: linear-gradient(to bottom, var(--accent), transparent);
      opacity: 0.25;
    }

    /* ── Single project block ── */
    .project-block {
      position: relative;
      padding: 0 0 7rem 3.5rem;
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .project-block.visible { opacity: 1; transform: none; }

    /* dot on the spine */
    .project-block::before {
      content: '';
      position: absolute;
      left: -4px; top: 8px;
      width: 9px; height: 9px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 12px rgba(201,169,110,0.5);
    }

    .project-date {
      font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--accent); opacity: 0.6; margin-bottom: 0.8rem;
    }
    .project-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem, 3vw, 3rem);
      font-weight: 300; line-height: 1.1;
      margin-bottom: 0.6rem;
    }
    .project-subtitle {
      font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 2rem; opacity: 0.7;
    }
    .project-desc {
      color: var(--muted); font-size: 0.88rem; line-height: 1.9;
      max-width: 680px; margin-bottom: 3rem;
    }

    /* ── Media grid inside a project ── */
    .project-media {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 3rem;
    }
    .media-item {
      position: relative; overflow: hidden;
      background: var(--surface);
      border: 1px solid var(--border);
      cursor: none;
      transition: border-color 0.3s;
    }
    .media-item:hover { border-color: var(--accent); }
    .media-item img {
      width: 100%; display: block; aspect-ratio: 4/3; object-fit: cover;
      filter: grayscale(15%) brightness(0.85);
      transition: transform 0.5s ease, filter 0.4s ease;
    }
    .media-item:hover img { transform: scale(1.05); filter: grayscale(0%) brightness(1); }

    /* Video embed */
    .media-item.video-item { aspect-ratio: 16/9; }
    .media-item.video-item iframe {
      width: 100%; height: 100%; display: block; border: none;
    }

    /* PDF / doc card */
    .media-item.doc-item {
      display: flex; flex-direction: column;
      justify-content: space-between;
      padding: 1.5rem; min-height: 160px;
      text-decoration: none;
    }
    .doc-icon {
      font-size: 1.8rem; opacity: 0.3; margin-bottom: 1rem;
      font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.1em;
      color: var(--accent);
    }
    .doc-name {
      font-family: 'Cormorant Garamond', serif; font-style: italic;
      font-size: 1rem; color: var(--text); line-height: 1.3;
      margin-bottom: 0.5rem;
    }
    .doc-meta {
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--accent); opacity: 0.6;
    }

    /* ── Research / references row ── */
    .project-refs {
      display: flex; flex-wrap: wrap; gap: 0.6rem;
      margin-bottom: 2rem;
    }
    .ref-tag {
      padding: 0.35rem 1rem;
      border: 1px solid var(--border);
      font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--muted); text-decoration: none;
      transition: all 0.3s;
    }
    .ref-tag:hover { background: var(--accent); border-color: var(--accent); color: var(--bg); }

    /* ── Expandable research notes ── */
    .project-notes-toggle {
      background: none; border: none; cursor: none;
      display: flex; align-items: center; gap: 0.8rem;
      font-family: 'DM Sans', sans-serif; font-size: 0.65rem;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--muted); padding: 0; margin-bottom: 1.5rem;
      transition: color 0.3s;
    }
    .project-notes-toggle:hover { color: var(--accent); }
    .toggle-icon {
      width: 18px; height: 18px; border: 1px solid currentColor;
      border-radius: 50%; position: relative; flex-shrink: 0;
      transition: transform 0.3s;
    }
    .toggle-icon::before, .toggle-icon::after {
      content: ''; position: absolute; top: 50%; left: 50%;
      background: currentColor;
    }
    .toggle-icon::before { width: 8px; height: 1px; transform: translate(-50%,-50%); }
    .toggle-icon::after  { width: 1px; height: 8px; transform: translate(-50%,-50%); transition: transform 0.3s, opacity 0.3s; }
    .project-notes-toggle.open .toggle-icon { transform: rotate(45deg); }

    .project-notes {
      max-height: 0; overflow: hidden;
      transition: max-height 0.6s cubic-bezier(0.77,0,0.18,1);
    }
    .project-notes.open { max-height: 1000px; }
    .project-notes-inner {
      padding: 2rem; border: 1px solid var(--border);
      background: var(--surface); margin-bottom: 2rem;
    }
    .project-notes-inner p {
      color: var(--muted); font-size: 0.85rem; line-height: 1.9;
      margin-bottom: 1rem;
    }
    .project-notes-inner p:last-child { margin-bottom: 0; }

    /* project divider */
    .project-block + .project-block::after {
      display: none;
    }

    /* ── ABOUT ── */
    #about {
      padding: 8rem 3rem; display: grid;
      grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;
      border-top: 1px solid var(--border);
    }
    @media (max-width: 768px) { #about { grid-template-columns: 1fr; gap: 3rem; } }
    .about-img-wrap { position: relative; aspect-ratio: 3/4; }
    .about-img-wrap img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(15%); }
    .about-img-wrap::before {
      content: ''; position: absolute; inset: -12px -12px 12px 12px;
      border: 1px solid var(--border); z-index: -1;
    }
    .about-label { font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; }
    .about-heading { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; line-height: 1.15; margin-bottom: 2rem; }
    .about-text { color: var(--muted); line-height: 1.9; font-size: 0.9rem; margin-bottom: 1.5rem; }
    .about-stats { display: flex; gap: 3rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); }
    .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; color: var(--accent); line-height: 1; }
    .stat-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-top: 0.4rem; }

    /* ── SERVICES ── */
    #services { padding: 8rem 3rem; border-top: 1px solid var(--border); }
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin-top: 4rem; }
    @media (max-width: 768px) { .services-grid { grid-template-columns: 1fr; } }
    .service-item {
      padding: 3rem; border: 1px solid var(--border);
      transition: background 0.3s; position: relative; overflow: hidden;
    }
    .service-item::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 2px; background: var(--accent); transition: width 0.5s ease; }
    .service-item:hover::after { width: 100%; }
    .service-item:hover { background: rgba(201,169,110,0.04); }
    .service-num { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 3rem; color: var(--border); line-height: 1; margin-bottom: 1.5rem; }
    .service-title { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; margin-bottom: 1rem; }
    .service-desc { color: var(--muted); font-size: 0.85rem; line-height: 1.8; }

    /* ── CONTACT ── */
    #contact { padding: 8rem 3rem; border-top: 1px solid var(--border); text-align: center; position: relative; overflow: hidden; }
    #contact::before {
      content: 'CONTACT'; font-family: 'Bebas Neue', sans-serif; font-size: 20vw;
      color: rgba(201,169,110,0.03); position: absolute; top: 50%; left: 50%;
      transform: translate(-50%,-50%); white-space: nowrap; pointer-events: none;
    }
    .contact-label { font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; }
    .contact-heading { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 300; line-height: 1.1; margin-bottom: 3rem; }
    .contact-heading em { font-style: italic; color: var(--accent); }
    .contact-email {
      display: inline-block; font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(1rem, 3vw, 1.8rem); letter-spacing: 0.1em;
      color: var(--text); text-decoration: none;
      border-bottom: 1px solid var(--accent); padding-bottom: 0.3rem; transition: color 0.3s;
    }
    .contact-email:hover { color: var(--accent); }
    .social-links { display: flex; justify-content: center; gap: 2rem; margin-top: 4rem; }
    .social-links a { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.3s; }
    .social-links a:hover { color: var(--accent); }

    /* ── FOOTER ── */
    footer { padding: 2rem 3rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
    footer p { font-size: 0.65rem; letter-spacing: 0.1em; color: var(--muted); }

    /* ── LIGHTBOX ── */
    .lightbox {
      position: fixed; inset: 0; z-index: 1000;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.5s ease;
    }
    .lightbox.open { opacity: 1; pointer-events: all; }
    .lightbox-backdrop { position: absolute; inset: 0; background: rgba(8,8,7,0.96); backdrop-filter: blur(14px); }
    .lightbox-inner { position: relative; z-index: 1; width: 90vw; max-width: 1200px; height: 82vh; display: flex; align-items: center; overflow: hidden; }
    .lightbox-img-pane { flex-shrink: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; transition: width 1s cubic-bezier(0.77,0,0.18,1); }
    .lightbox.open .lightbox-img-pane { width: 60%; }
    .lightbox-img-pane img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; opacity: 0; }
    .lightbox.open .lightbox-img-pane img { animation: lbImgEntrance 1.1s cubic-bezier(0.77,0,0.18,1) forwards; }
    @keyframes lbImgEntrance {
      0%   { transform: scale(0.85); opacity: 0; }
      45%  { transform: scale(1.22); opacity: 1; }
      100% { transform: scale(1);    opacity: 1; }
    }
    .lightbox-divider-v { flex-shrink: 0; width: 1px; height: 60%; background: linear-gradient(to bottom, transparent, #c9a96e, transparent); opacity: 0; transition: opacity 0.6s ease 0.7s; }
    .lightbox.open .lightbox-divider-v { opacity: 0.3; }
    .lightbox-desc-pane { flex-shrink: 0; width: 0%; height: 100%; overflow: hidden; transition: width 1s cubic-bezier(0.77,0,0.18,1); }
    .lightbox.open .lightbox-desc-pane { width: 40%; }
    .lightbox-desc-content { padding: 0 2.5rem 0 2rem; opacity: 0; transform: translateX(30px); transition: opacity 0.8s ease 0.65s, transform 0.8s ease 0.65s; min-width: 260px; }
    .lightbox.open .lightbox-desc-content { opacity: 1; transform: translateX(0); }
    .lb-eyebrow { font-size: 0.58rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--accent); opacity: 0.6; margin-bottom: 1.2rem; }
    .lb-title { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: clamp(1.6rem, 2.5vw, 2.6rem); font-weight: 300; line-height: 1.1; color: var(--text); margin-bottom: 1.5rem; }
    .lb-rule { width: 36px; height: 1px; background: var(--accent); opacity: 0.45; margin-bottom: 1.5rem; }
    .lb-body { font-size: 0.82rem; line-height: 1.9; color: rgba(122,116,104,0.8); margin-bottom: 2rem; }
    .lb-meta { display: flex; flex-direction: column; gap: 0.7rem; }
    .lb-meta-row { display: flex; gap: 1rem; align-items: baseline; }
    .lb-meta-label { font-size: 0.53rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--accent); opacity: 0.55; min-width: 58px; }
    .lb-meta-val { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.05em; }
    .lb-close { position: absolute; top: -2.8rem; right: 0; background: none; border: none; cursor: none; color: var(--muted); font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; display: flex; align-items: center; gap: 0.7rem; transition: color 0.3s; padding: 0; }
    .lb-close:hover { color: var(--accent); }
    .lb-close-icon { width: 22px; height: 22px; position: relative; }
    .lb-close-icon::before, .lb-close-icon::after { content: ''; position: absolute; top: 50%; left: 50%; width: 100%; height: 1px; background: currentColor; }
    .lb-close-icon::before { transform: translate(-50%,-50%) rotate(45deg); }
    .lb-close-icon::after  { transform: translate(-50%,-50%) rotate(-45deg); }
    .lb-nav { position: absolute; bottom: -3rem; left: 0; display: flex; gap: 1.2rem; }
    .lb-nav button { background: none; border: 1px solid var(--border); color: var(--muted); font-family: 'DM Sans', sans-serif; font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0.45rem 1.1rem; cursor: none; transition: all 0.3s; }
    .lb-nav button:hover { background: var(--accent); border-color: var(--accent); color: var(--bg); }
    .lb-counter { position: absolute; bottom: -2.7rem; right: 0; font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 0.82rem; color: var(--muted); opacity: 0.45; }

    /* ── ANIMATIONS ── */
